# =============================================================================
# LOCAL DEVELOPMENT CONFIGURATION (Option A: Fully Local, No API Costs)
# =============================================================================
# Copy this to .env: cp .env.local .env

APP_ENV=development
LOG_LEVEL=INFO

# =============================================================================
# LLM - Ollama (runs locally, no API key needed)
# =============================================================================
# First install Ollama: brew install ollama
# Then pull a model: ollama pull llama3.1
# Start Ollama: ollama serve (in a separate terminal)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
LLM_BASE_URL=http://localhost:11434

# =============================================================================
# Embeddings - BGE-M3 (runs locally, no API key needed)
# =============================================================================
# Model downloads automatically on first use (~2GB)
# Runs in-process, no separate service needed
EMBEDDING_PROVIDER=bge-m3
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_USE_FP16=true
EMBEDDING_DEVICE=mps
# Use 'mps' for Apple Silicon GPU acceleration
# Use 'cpu' if you have issues with MPS
# Leave empty for auto-detection

# =============================================================================
# Vector Store - ChromaDB (runs locally, no service needed)
# =============================================================================
# Runs in-process with file persistence
# No separate service or database to start
VECTOR_STORE_PROVIDER=chromadb
CHROMA_PERSIST_DIR=./chroma_db

# =============================================================================
# Excel Extraction
# =============================================================================
# openpyxl is best for pivot tables and charts
EXTRACTION_STRATEGY=openpyxl
ENABLE_LLM_SUMMARIZATION=false
# Set to true if you want LLM to summarize each sheet (uses more LLM calls)

# =============================================================================
# Cache - In-Memory (no Redis needed)
# =============================================================================
CACHE_BACKEND=memory

# =============================================================================
# Database - SQLite (local file)
# =============================================================================
SQLITE_DB_PATH=./data/metadata.db

# =============================================================================
# API Settings
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# Advanced RAG Features (optional - can disable for faster responses)
# =============================================================================
ENABLE_RERANKING=false
ENABLE_HYBRID_SEARCH=false
ENABLE_HYDE=false
# Set these to true for better quality but slower responses

# =============================================================================
# Google Drive - NOT NEEDED for local file upload
# =============================================================================
# Leave these empty - you can upload files directly via the web UI
# Only configure if you want to connect to Google Drive
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# =============================================================================
# Security Keys - Defaults provided for local dev
# =============================================================================
# These have safe defaults for local development
# In production, always set these to secure random values
# TOKEN_ENCRYPTION_KEY=  # Has default
# JWT_SECRET_KEY=  # Has default
