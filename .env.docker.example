# Google Drive Excel RAG System - Docker Environment Configuration
# Copy this file to .env for Docker deployment
# This file contains all environment variables needed for docker-compose

# ============================================================================
# Application Environment
# ============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================================================
# Google Drive OAuth Configuration
# ============================================================================
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Google Drive API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URI: http://localhost:8000/api/v1/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# ============================================================================
# Vector Store Configuration
# ============================================================================
# Using ChromaDB service from docker-compose
VECTOR_STORE_PROVIDER=chromadb
CHROMA_PERSIST_DIR=/app/chroma_db
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ============================================================================
# Embedding Service Configuration
# ============================================================================
# Embedding provider: openai, sentence-transformers, cohere
EMBEDDING_PROVIDER=openai

# API key for embedding service
# Get from: https://platform.openai.com/api-keys
EMBEDDING_API_KEY=your_openai_api_key_here

# Embedding model
# Options: text-embedding-3-small (1536 dim), text-embedding-3-large (3072 dim)
EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# LLM Service Configuration
# ============================================================================
# LLM provider: openai, anthropic, gemini
LLM_PROVIDER=openai

# API key for LLM service
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/
# Gemini: https://makersuite.google.com/app/apikey
LLM_API_KEY=your_llm_api_key_here

# LLM model
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# Gemini: gemini-pro
LLM_MODEL=gpt-4

# ============================================================================
# Cache Configuration
# ============================================================================
# Cache provider: memory (simple) or redis (production)
CACHE_PROVIDER=memory

# Redis configuration (if using redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================================================
# Web Authentication Configuration
# ============================================================================
# JWT secret key for web authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here

# Token encryption key (MUST be at least 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TOKEN_ENCRYPTION_KEY=your_32_character_or_longer_encryption_key_here

# Web UI credentials (hardcoded for local deployment)
WEB_AUTH_USERNAME=girish
WEB_AUTH_PASSWORD=Girish@123

# ============================================================================
# File Upload Configuration
# ============================================================================
# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=100

# Upload directory (inside container)
UPLOAD_DIR=/app/uploads

# ============================================================================
# Language Processing Configuration
# ============================================================================
# Supported languages: en (English), th (Thai)
SUPPORTED_LANGUAGES=en,th

# Default language
DEFAULT_LANGUAGE=en

# Enable English lemmatization (handles plurals, tenses)
ENABLE_LEMMATIZATION=true

# Thai tokenizer engine: newmm (recommended), longest, deepcut
THAI_TOKENIZER_ENGINE=newmm

# ============================================================================
# Extraction Configuration
# ============================================================================
# Enable LLM-based sheet summarization for better query matching
ENABLE_LLM_SUMMARIZATION=true

# Summarization provider (uses LLM_PROVIDER if not specified)
SUMMARIZATION_PROVIDER=openai

# Maximum tokens for sheet summaries
SUMMARIZATION_MAX_TOKENS=150

# Enable Gemini extraction (optional, requires GEMINI_API_KEY)
ENABLE_GEMINI_EXTRACTION=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_FALLBACK_ON_ERROR=true

# Enable LlamaParse extraction (optional, requires LLAMAPARSE_API_KEY)
ENABLE_LLAMAPARSE=false
LLAMAPARSE_API_KEY=

# Use automatic extraction strategy selection
USE_AUTO_EXTRACTION_STRATEGY=false
EXTRACTION_COMPLEXITY_THRESHOLD=0.7

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000

# CORS origins (comma-separated, use * for development)
CORS_ORIGINS=*

# ============================================================================
# Indexing Configuration
# ============================================================================
# Maximum concurrent files during indexing
MAX_CONCURRENT_FILES=5

# Maximum rows per Excel sheet
MAX_ROWS_PER_SHEET=10000

# Batch size for embedding generation
BATCH_SIZE=100

# ============================================================================
# Query Configuration
# ============================================================================
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# Number of top results from vector search
TOP_K_RESULTS=10

# Confidence threshold for automatic selection
CONFIDENCE_THRESHOLD=0.7

# ============================================================================
# ChromaDB Configuration
# ============================================================================
# Disable ChromaDB telemetry
ANONYMIZED_TELEMETRY=FALSE

# ============================================================================
# Notes for Docker Deployment
# ============================================================================
# 1. Copy this file to .env: cp .env.docker.example .env
# 2. Fill in your API keys and credentials
# 3. Build and start services: docker-compose up -d
# 4. Check logs: docker-compose logs -f
# 5. Access application: http://localhost:8000
# 6. Access ChromaDB: http://localhost:8001
#
# Data Persistence:
# - All data is stored in Docker volumes
# - Volumes: app-data, uploads, logs, tokens, chroma-data
# - Backup volumes: docker-compose exec web tar -czf /backup.tar.gz /app/data /app/uploads
# - Restore volumes: docker-compose exec web tar -xzf /backup.tar.gz
#
# Troubleshooting:
# - View logs: docker-compose logs -f web
# - Check health: curl http://localhost:8000/health
# - Restart services: docker-compose restart
# - Rebuild: docker-compose up -d --build
#
# Security:
# - Change WEB_AUTH_PASSWORD before deployment
# - Use strong JWT_SECRET_KEY and TOKEN_ENCRYPTION_KEY
# - Never commit .env file to version control
# - Rotate API keys regularly
# - Use HTTPS in production with reverse proxy (nginx, traefik)

