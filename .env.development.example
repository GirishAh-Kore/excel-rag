# Development Profile - Local Development with ChromaDB
# Copy to .env for local development

APP_ENV=development
LOG_LEVEL=DEBUG

# Google Drive OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive.readonly
TOKEN_STORAGE_PATH=./tokens
TOKEN_ENCRYPTION_KEY=your_32_character_or_longer_encryption_key_here

# Vector Store - ChromaDB for local development
VECTOR_STORE_PROVIDER=chromadb
CHROMA_PERSIST_DIR=./chroma_db

# Embedding - Sentence Transformers (free, local)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM - OpenAI GPT-3.5 (cost-effective for development)
LLM_PROVIDER=openai
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-3.5-turbo

# Database
SQLITE_DB_PATH=./data/metadata.db

# Indexing
MAX_CONCURRENT_FILES=3
MAX_ROWS_PER_SHEET=5000
BATCH_SIZE=50

# Query
SESSION_TIMEOUT_MINUTES=30
TOP_K_RESULTS=10
CONFIDENCE_THRESHOLD=0.7

# API
API_HOST=127.0.0.1
API_PORT=8000
API_RATE_LIMIT=100
