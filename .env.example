# Google Drive Excel RAG System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Application Environment
# ============================================================================
# Options: development, staging, production
APP_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Google Drive OAuth Configuration
# ============================================================================
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Google Drive API
# 3. Create OAuth 2.0 credentials (Desktop app or Web app)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth redirect URI (must match what's configured in Google Cloud Console)
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Google Drive API scopes (comma-separated)
# readonly: Only read files
# full: Read and write files
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive.readonly

# Path to store encrypted OAuth tokens
TOKEN_STORAGE_PATH=./tokens

# Encryption key for token storage (MUST be at least 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TOKEN_ENCRYPTION_KEY=your_32_character_or_longer_encryption_key_here

# ============================================================================
# Vector Store Configuration
# ============================================================================
# Vector store provider: chromadb (MVP/local) or opensearch (production)
VECTOR_STORE_PROVIDER=chromadb

# ChromaDB Configuration (for MVP/local development)
CHROMA_PERSIST_DIR=./chroma_db

# OpenSearch Configuration (for production)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_USE_SSL=true

# ============================================================================
# Embedding Service Configuration
# ============================================================================
# Embedding provider: openai, sentence-transformers, cohere, bge, bge-m3
EMBEDDING_PROVIDER=openai

# API key for embedding service (not needed for sentence-transformers or bge)
EMBEDDING_API_KEY=your_embedding_api_key_here

# Embedding model name
# OpenAI options: text-embedding-3-small (1536 dim), text-embedding-3-large (3072 dim)
# Sentence Transformers options: all-MiniLM-L6-v2 (384 dim), all-mpnet-base-v2 (768 dim)
# Cohere options: embed-english-v3.0 (1024 dim), embed-english-light-v3.0 (384 dim)
# BGE options: BAAI/bge-m3 (1024 dim, multilingual), BAAI/bge-large-en-v1.5 (1024 dim)
EMBEDDING_MODEL=text-embedding-3-small

# Maximum retry attempts for API-based embedding services
EMBEDDING_MAX_RETRIES=3

# BGE-specific options (for local embedding)
EMBEDDING_USE_FP16=true
EMBEDDING_DEVICE=  # cuda, cpu, mps, or leave empty for auto-detect
EMBEDDING_MAX_LENGTH=8192

# ============================================================================
# LLM Service Configuration
# ============================================================================
# LLM provider: openai, anthropic, gemini, vllm, ollama
LLM_PROVIDER=openai

# API key for LLM service (not needed for ollama, optional for vllm)
LLM_API_KEY=your_llm_api_key_here

# LLM model name
# OpenAI options: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic options: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# Gemini options: gemini-pro, gemini-1.5-flash
# vLLM/Ollama options: llama3.1, mistral, qwen2.5, phi3
LLM_MODEL=gpt-4o

# vLLM/Ollama server URL (for local LLM deployment)
LLM_BASE_URL=http://localhost:8000/v1  # vLLM default
# LLM_BASE_URL=http://localhost:11434  # Ollama default

# Request timeout for LLM calls (seconds)
LLM_TIMEOUT=120

# ============================================================================
# Database Configuration
# ============================================================================
# Path to SQLite database for metadata storage
SQLITE_DB_PATH=./data/metadata.db

# ============================================================================
# Indexing Pipeline Configuration
# ============================================================================
# Maximum number of files to process concurrently
MAX_CONCURRENT_FILES=5

# Maximum rows to process per Excel sheet (to prevent memory issues)
MAX_ROWS_PER_SHEET=10000

# Batch size for embedding generation (texts per API call)
BATCH_SIZE=100

# ============================================================================
# Query Processing Configuration
# ============================================================================
# Session timeout for conversation context (in minutes)
SESSION_TIMEOUT_MINUTES=30

# Number of top results to retrieve from vector search
TOP_K_RESULTS=10

# Confidence threshold for automatic file selection (0.0 to 1.0)
# Below this threshold, user will be asked to clarify
CONFIDENCE_THRESHOLD=0.7

# ============================================================================
# API Server Configuration
# ============================================================================
# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# Rate limit (requests per minute per IP)
API_RATE_LIMIT=100

# ============================================================================
# Language Processing Configuration
# ============================================================================
# Supported languages (comma-separated): en (English), th (Thai)
SUPPORTED_LANGUAGES=en,th

# Default language for the system
DEFAULT_LANGUAGE=en

# Enable automatic language detection
ENABLE_LANGUAGE_DETECTION=true

# Minimum confidence threshold for language detection (0.0 to 1.0)
LANGUAGE_DETECTION_CONFIDENCE_THRESHOLD=0.8

# Enable English lemmatization (handles plurals, tenses)
# "expenses" → "expense", "sold" → "sell"
ENABLE_LEMMATIZATION=true

# Enable Thai tokenization (required for Thai word segmentation)
ENABLE_THAI_TOKENIZATION=true

# Thai tokenizer engine: newmm (fast, accurate), longest, deepcut (ML-based)
THAI_TOKENIZER_ENGINE=newmm

# Semantic matching threshold (0.0 to 1.0)
# Below this threshold, fallback to keyword matching
SEMANTIC_MATCH_THRESHOLD=0.7

# Enable keyword matching as fallback when semantic matching confidence is low
ENABLE_KEYWORD_FALLBACK=true

# Enable fuzzy string matching for typos and variations
ENABLE_FUZZY_MATCHING=true

# Fuzzy matching threshold (0.0 to 1.0)
FUZZY_MATCH_THRESHOLD=0.85

# Preprocess text before embedding (tokenize + normalize)
# Recommended: true for better matching accuracy
PREPROCESS_BEFORE_EMBEDDING=true

# ============================================================================
# Cache Configuration
# ============================================================================
# Cache backend: redis (production) or memory (development/MVP)
CACHE_BACKEND=memory

# Redis Cache Configuration (for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=rag:
REDIS_SERIALIZER=json  # json or pickle

# In-Memory Cache Configuration (for development/MVP)
MEMORY_CACHE_MAX_SIZE=1000
MEMORY_CACHE_DEFAULT_TTL=3600  # seconds (1 hour)

# ============================================================================
# Vector Store Migration Configuration
# ============================================================================
# When migrating between vector stores (e.g., ChromaDB to OpenSearch),
# ensure both source and target configurations are set correctly.
#
# Migration command:
#   python scripts/migrate_vector_store.py --source chromadb --target opensearch
#
# Rollback command:
#   python scripts/migrate_vector_store.py --source opensearch --target chromadb --rollback
#
# See docs/MIGRATION.md for detailed migration guide

# ============================================================================
# Profile-Specific Configurations
# ============================================================================
# You can create multiple .env files for different environments:
# - .env.development (local development with ChromaDB + OpenAI)
# - .env.staging (staging with OpenSearch + OpenAI)
# - .env.production (production with OpenSearch + Claude)
#
# Load specific profile with: export APP_ENV=production

# ============================================================================
# Example Configurations
# ============================================================================

# Example 1: MVP Configuration (Local Development)
# VECTOR_STORE_PROVIDER=chromadb
# EMBEDDING_PROVIDER=sentence-transformers
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-3.5-turbo

# Example 2: Production Configuration (Cloud)
# VECTOR_STORE_PROVIDER=opensearch
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-large
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022

# Example 3: Cost-Optimized Configuration
# VECTOR_STORE_PROVIDER=chromadb
# EMBEDDING_PROVIDER=sentence-transformers
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-3.5-turbo

# Example 4: Fully Open-Source / Local Configuration (No API Costs)
# VECTOR_STORE_PROVIDER=chromadb
# EMBEDDING_PROVIDER=bge-m3
# EMBEDDING_MODEL=BAAI/bge-m3
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
# LLM_BASE_URL=http://localhost:11434
# EXTRACTION_STRATEGY=docling
# ENABLE_DOCLING=true

# Example 5: High-Performance Local with vLLM
# VECTOR_STORE_PROVIDER=chromadb
# EMBEDDING_PROVIDER=bge-m3
# EMBEDDING_MODEL=BAAI/bge-m3
# LLM_PROVIDER=vllm
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# LLM_BASE_URL=http://localhost:8000/v1
# EXTRACTION_STRATEGY=unstructured
# ENABLE_UNSTRUCTURED=true

# ============================================================================
# Extraction Strategy Configuration
# ============================================================================
# Default extraction strategy: openpyxl, gemini, llamaparse, docling, unstructured, auto
EXTRACTION_STRATEGY=openpyxl

# Enable Docling (IBM open-source document understanding)
ENABLE_DOCLING=false
DOCLING_MODEL=default

# Enable Unstructured.io (document chunking for RAG) - FULLY OPEN SOURCE
# Runs locally by default, no API key needed
# Install: pip install "unstructured[xlsx]"
ENABLE_UNSTRUCTURED=false
UNSTRUCTURED_API_KEY=  # Only needed for hosted SaaS (optional)
UNSTRUCTURED_API_URL=  # Only needed for self-hosted API server (optional)
UNSTRUCTURED_STRATEGY=auto  # auto, fast, hi_res

# ============================================================================
# Notes
# ============================================================================
# - Never commit the actual .env file to version control
# - Keep API keys secure and rotate them regularly
# - Use different encryption keys for different environments
# - Monitor API usage and costs for cloud providers
# - Test configuration with: python -m src.config
