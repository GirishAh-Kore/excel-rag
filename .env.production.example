# Production Profile - OpenSearch + Claude
# Copy to .env for production deployment

APP_ENV=production
LOG_LEVEL=INFO

# Google Drive OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive.readonly
TOKEN_STORAGE_PATH=/var/app/tokens
TOKEN_ENCRYPTION_KEY=your_32_character_or_longer_encryption_key_here

# Vector Store - OpenSearch for production scalability
VECTOR_STORE_PROVIDER=opensearch
OPENSEARCH_HOST=your-opensearch-host.com
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your_secure_password_here
OPENSEARCH_USE_SSL=true

# Embedding - OpenAI (high quality)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_MAX_RETRIES=5

# LLM - Anthropic Claude (high quality, reliable)
LLM_PROVIDER=anthropic
LLM_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-3-5-sonnet-20241022

# Database
SQLITE_DB_PATH=/var/app/data/metadata.db

# Indexing - Higher concurrency for production
MAX_CONCURRENT_FILES=10
MAX_ROWS_PER_SHEET=10000
BATCH_SIZE=100

# Query
SESSION_TIMEOUT_MINUTES=30
TOP_K_RESULTS=10
CONFIDENCE_THRESHOLD=0.7

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=1000
